# .env.example
# このファイルをコピーして .env を作り、実際のキーを入力してください
# cp .env.example .env

ANTHROPIC_API_KEY=sk-ant-ここにAPIキーを入力

# Slack Incoming Webhook URL（通知する場合）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# 公開サイトのベースURL（末尾スラッシュなし）。例: https://medical-topics-ryo.surge.sh
# GitHub Actions では必須（Slack に載せる当日 URL のため）。
# ローカルでは未設定の場合、Slack 通知はスキップされます（警告ログのみ）。
PUBLIC_URL=
