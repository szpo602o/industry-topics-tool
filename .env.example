# .env.example
# このファイルをコピーして .env を作り、実際のキーを入力してください
# cp .env.example .env

ANTHROPIC_API_KEY=sk-ant-ここにAPIキーを入力

# Slack Incoming Webhook URL（通知を使う場合のみ設定）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# 公開サイトのベースURLのみ（例: https://medical-topics-ryo.surge.sh 末尾スラッシュなし）
# 当日ページURLは {PUBLIC_URL}/{YYYY-MM-DD}/ として通知される。未設定ならローカルパスを通知
PUBLIC_URL=

# Slack 各行に使うテキスト（title または summary。summary 空のときは title にフォールバック）
# SLACK_NOTIFY_TEXT_FIELD=title
